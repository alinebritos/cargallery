# =============================================================================
# Car Gallery Website Design — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# O arquivo .env é ignorado pelo Git (.gitignore) e NUNCA deve ser commitado.
# =============================================================================

# --- Supabase (obrigatório) ---
# URL do projeto — Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon) — Dashboard > Settings > API > Project API keys > anon public
# Segura para uso no front-end (Vite expõe variáveis VITE_* no browser).
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# --- Apenas server-side / CI (NUNCA prefixo VITE_) ---
# Chave service_role — NUNCA usar no front-end. Apenas scripts, Edge Functions ou CI.
# SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
